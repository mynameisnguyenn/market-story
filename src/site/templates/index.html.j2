<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#0d0c0c">
  <title>{{ title }}</title>
  <link rel="manifest" href="assets/manifest.webmanifest">
  <link rel="apple-touch-icon" href="assets/icon-192.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Mono:wght@500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="assets/style.css">
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
</head>
<body>
  <header class="masthead">
    <div class="masthead-row">
      <h1>Global Markets Brief</h1>
      <div class="stamp">{{ session_label }} · generated {{ generated }}</div>
    </div>
    {{ header | safe }}
  </header>

  <nav class="tabs" role="tablist">
    {% for tab in tabs %}
    <button class="tab{% if loop.first %} active{% endif %}" role="tab"
            data-target="{{ tab.id }}">{{ tab.label }}</button>
    {% endfor %}
  </nav>

  <main>
    {% for tab in tabs %}
    <div class="tabpanel{% if loop.first %} active{% endif %}" id="{{ tab.id }}" role="tabpanel">
      {{ tab.html | safe }}
    </div>
    {% endfor %}
  </main>

  <footer class="foot">
    <span>market-story · static build · {{ date }}</span>
    <span>Claude is the brain. Data: yfinance · FRED · BLS · EIA · CFTC · SEC.</span>
  </footer>

  <script src="assets/app.js"></script>
</body>
</html>
