# Copy this file to `.env` and fill in.  `.env` is gitignored — keys never leave your machine.
# All keys are FREE and OPTIONAL: the app degrades gracefully without them, but they make
# the data layer more reliable (and energy/positioning need their respective keys).

# FRED — used keyed-first (reliable under load), else the keyless CSV endpoint.
#   free key: https://fredaccount.stlouisfed.org/apikeys   (2 min, no card)
FRED_API_KEY=

# EIA — REQUIRED for the weekly energy-inventory panel (no key -> the panel just hides).
#   free key: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# BLS — optional; keyless v1 works. A free key raises the daily limit + unlocks v2.
#   free key: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# SEC EDGAR — keyless, but SEC asks for a contact in the User-Agent. Put "your name email".
SEC_USER_AGENT=

# CFTC positioning and yfinance/RSS need no key.
