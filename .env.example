# Copy to .env and fill in. .env is gitignored.
# FRED is optional — the app falls back to the keyless CSV endpoint if this is blank.
FRED_API_KEY=
# BLS is optional too — keyless v1 works; a free key (data.bls.gov/registrationEngine)
# raises the daily limit and unlocks the v2 endpoint.
BLS_API_KEY=
# SEC EDGAR is keyless but requires a descriptive User-Agent. The default is fine;
# override here with your own "name email" if you prefer (SEC asks for a contact).
SEC_USER_AGENT=
