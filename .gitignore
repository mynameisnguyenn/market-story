# --- Environments ---
venv/
.venv/
env/
__pycache__/
*.pyc

# --- Secrets ---
.env
*.key

# --- Generated data: briefs + history.db regenerate each run and stay out of git.
#     narratives/ are KEPT as a dated logbook (and so the hosted Story tab works). ---
data/briefs/
data/emails/
data/*.db
*.parquet
*.cache

# --- Static site build output (regenerated by build_site.py; deployed to Pages by the Action) ---
# root-anchored (/site/) so it does NOT also ignore the generator package src/site/
/site/

# --- Images: keep only curated portfolio outputs + the landing social card ---
*.png
!results/*.png
!docs/*.png
# commit the market-story-design skill's brand assets despite the *.png ignore above
!.claude/skills/**/*.png
# commit the PWA app icons (generated once by src/site/make_icons.py, served by the static site)
!src/site/static/*.png

# --- Tools / binaries ---
bin/

# --- Scratch: design exports (Claude Design / Figma) — translated into styles.css, not committed ---
design-import/

# --- OS / IDE ---
.DS_Store
.vscode/
.idea/
.streamlit/secrets.toml
